@page "/confirm"
@rendermode InteractiveServer

<!DOCTYPE html>

<html dir="rtl" lang="ar"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>تأكيد التحويل | البنك الخاص الرقمي</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;family=Noto+Sans+Arabic:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed-dim": "#b7c4ff",
                        "tertiary": "#952200",
                        "secondary-container": "#dae2fd",
                        "on-tertiary-container": "#ffddd5",
                        "primary": "#003ec7",
                        "on-background": "#191c1e",
                        "surface-tint": "#004ced",
                        "outline": "#737688",
                        "surface-container-high": "#e6e8ea",
                        "on-primary-container": "#dfe3ff",
                        "on-secondary-container": "#5c647a",
                        "surface-container-highest": "#e0e3e5",
                        "on-error": "#ffffff",
                        "secondary-fixed-dim": "#bec6e0",
                        "inverse-primary": "#b7c4ff",
                        "on-secondary-fixed-variant": "#3f465c",
                        "on-tertiary-fixed-variant": "#891e00",
                        "surface-dim": "#d8dadc",
                        "tertiary-fixed-dim": "#ffb4a1",
                        "on-secondary": "#ffffff",
                        "error-container": "#ffdad6",
                        "error": "#ba1a1a",
                        "surface": "#f7f9fb",
                        "surface-bright": "#f7f9fb",
                        "on-secondary-fixed": "#131b2e",
                        "surface-container-low": "#f2f4f6",
                        "on-tertiary": "#ffffff",
                        "tertiary-container": "#bf3003",
                        "on-primary-fixed": "#001452",
                        "on-surface": "#191c1e",
                        "on-tertiary-fixed": "#3c0800",
                        "secondary": "#565e74",
                        "secondary-fixed": "#dae2fd",
                        "inverse-on-surface": "#eff1f3",
                        "surface-container": "#eceef0",
                        "tertiary-fixed": "#ffdbd2",
                        "inverse-surface": "#2d3133",
                        "primary-container": "#0052ff",
                        "on-error-container": "#93000a",
                        "on-primary": "#ffffff",
                        "outline-variant": "#c3c5d9",
                        "on-primary-fixed-variant": "#0038b6",
                        "surface-variant": "#e0e3e5",
                        "on-surface-variant": "#434656",
                        "primary-fixed": "#dde1ff",
                        "background": "#f7f9fb"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Noto Sans Arabic", "Manrope"],
                        "body": ["Noto Sans Arabic", "Inter"],
                        "label": ["Noto Sans Arabic", "Inter"]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .no-border-tonal-shift { border: none !important; }
        .wealth-card-gradient {
            background: linear-gradient(135deg, #003ec7 0%, #0052ff 100%);
        }
        .glass-nav {
            backdrop-filter: blur(20px);
        }
        body {
            font-family: 'Noto Sans Arabic', sans-serif;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
<main class="pt-24 pb-32 px-4 max-w-4xl mx-auto">
<!-- Back Button -->
<NavLink href="/send" class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-all group mb-8">
<span class="material-symbols-outlined text-lg group-active:translate-x-1 duration-150">arrow_forward</span>
<span class="font-label font-medium">تعديل التفاصيل</span>
</NavLink>
<header class="mb-12">
<h1 class="font-headline font-extrabold text-4xl tracking-tight text-on-surface mb-2">مراجعة التحويل</h1>
<p class="font-body text-on-surface-variant text-lg">يرجى التأكد من صحة المستلم والمبلغ قبل المتابعة.</p>
</header>
<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
<!-- Right Column: Transaction Details (Swapped position for RTL layout flow) -->
<div class="md:col-span-7 space-y-6">
<!-- Wealth Card Styled Summary -->
<div class="wealth-card-gradient rounded-full p-8 text-white shadow-lg shadow-primary/20 relative overflow-hidden">
<div class="absolute top-0 left-0 w-32 h-32 bg-white/5 rounded-full -ml-16 -mt-16 blur-3xl"></div>
<div class="relative z-10">
<p class="font-label text-white/70 uppercase tracking-widest text-[10px] mb-1">المبلغ المراد إرساله</p>
<div class="font-headline font-extrabold text-5xl mb-6 flex items-baseline">
<span class="text-2xl ml-1 font-medium">$</span>
<span>2,450.00</span>
</div>
<div class="flex items-center gap-2 bg-white/10 w-fit px-3 py-1 rounded-full backdrop-blur-md">
<span class="material-symbols-outlined text-sm">lock</span>
<span class="text-xs font-medium">تحويل فوري آمن</span>
</div>
</div>
</div>
<!-- Recipient Info Card -->
<div class="bg-surface-container-lowest rounded-full p-8 shadow-[0_10px_30px_rgba(0,0,0,0.04)]">
<h3 class="font-headline font-bold text-lg mb-6">تفاصيل المستلم</h3>
<div class="flex items-center gap-6 mb-8">
<div class="w-16 h-16 rounded-full bg-secondary-fixed flex items-center justify-center">
<span class="font-headline font-bold text-2xl text-on-secondary-fixed">جم</span>
</div>
<div>
<p class="font-headline font-bold text-xl text-on-surface">جوليان مارتينيز</p>
<p class="font-body text-on-surface-variant" dir="ltr">الحساب: ****8842</p>
</div>
</div>

</div>
</div>
<!-- Left Column: Final Confirmation Action -->
<div class="md:col-span-5">
<div class="bg-surface-container-low rounded-full p-8 sticky top-28 border border-white/50">
<h3 class="font-headline font-bold text-lg mb-6">ملخص العملية</h3>
<div class="space-y-4 mb-8">
<div class="flex justify-between">
<span class="font-body text-on-surface-variant">مبلغ التحويل</span>
<span class="font-label font-semibold" dir="ltr">$@Amount.00</span>
</div>
<div class="flex justify-between">
<span class="font-body text-on-surface-variant">رسوم الخدمة</span>
<span class="font-label font-semibold text-primary">مجاني</span>
</div>
<div class="pt-4 mt-4 border-t border-outline-variant/20 flex justify-between items-baseline">
<span class="font-headline font-bold text-on-surface">إجمالي الخصم</span>
<span class="font-headline font-extrabold text-2xl text-on-surface" dir="ltr">$2,450.00</span>
</div>
</div>
<div class="space-y-4">
<button class="w-full wealth-card-gradient text-white font-headline font-bold py-4 rounded-full shadow-lg shadow-primary/25 active:scale-[0.98] transition-transform">
                            تأكيد التحويل
                        </button>
<p class="text-center font-label text-[10px] text-on-surface-variant leading-relaxed px-4">
                            من خلال النقر على "تأكيد"، فإنك تخول البنك الخاص الرقمي بمعالجة هذه المعاملة على الفور.
                        </p>
</div>
</div>
<!-- Identity Verification Badge -->
<div class="mt-6 flex items-center justify-center gap-3 grayscale opacity-60">
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified_user</span>
<span class="font-label text-xs font-semibold tracking-wide uppercase">بروتوكول أمني مشفر</span>
</div>
</div>
</div>
</main>

<!-- BottomNavBar (JSON Managed - Mobile Only) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0_-10px_30px_rgba(0,0,0,0.04)] rounded-t-3xl">
<NavLink href="/dashboard" class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2">
<span class="material-symbols-outlined">home</span>
<span class="font-body text-[10px] font-medium tracking-wide">الرئيسية</span>
</NavLink>
<NavLink href="/send" class="flex flex-col items-center justify-center bg-blue-600 text-white rounded-full p-3 scale-110 -translate-y-2 shadow-lg shadow-blue-500/30">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
<span class="font-body text-[10px] font-medium tracking-wide">إرسال</span>
</NavLink>
<NavLink href="/receive" class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2">
<span class="material-symbols-outlined">qr_code_scanner</span>
<span class="font-body text-[10px] font-medium tracking-wide">استلام</span>
</NavLink>
<NavLink href="info" class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500 p-2">
<span class="material-symbols-outlined">account_circle</span>
<span class="font-body text-[10px] font-medium tracking-wide">الحساب</span>
</NavLink>
</nav>
</body></html>

@code {
    [Parameter]
    public double Amount{ get; set; }
}
